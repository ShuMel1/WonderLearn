ALTER TABLE WordProgress RENAME TO WordProgressLegacy;

CREATE TABLE WordProgress (
  wordId TEXT NOT NULL,
  languageCode TEXT NOT NULL,
  streak INTEGER NOT NULL DEFAULT 0,
  PRIMARY KEY (wordId, languageCode)
);

INSERT INTO WordProgress(wordId, languageCode, streak)
SELECT wordId,
       COALESCE((SELECT value FROM AppSetting WHERE key = 'language'), 'en'),
       streak
FROM WordProgressLegacy;

DROP TABLE WordProgressLegacy;
